<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:minHeight="?android:attr/listPreferredItemHeight"
    android:paddingStart="?android:attr/listPreferredItemPaddingStart"
    android:paddingEnd="?android:attr/listPreferredItemPaddingEnd"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@android:id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceLarge"
        android:singleLine="true"
        android:ellipsize="marquee"
        android:fadingEdge="horizontal"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@android:id/summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?android:attr/textAppearanceSmall"
        android:textColor="?android:attr/textColorSecondary"
        android:maxLines="10"
        android:ellipsize="end"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp" />

    <!-- Two tappable card views side by side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false"
        android:layout_marginBottom="16dp">

        <!-- Default list view card -->
        <FrameLayout
            android:id="@+id/default_list_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/preference_caddy_card_background"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center"
                android:minHeight="100dp">

                <!-- Default list illustration -->
                <LinearLayout
                    android:id="@+id/default_list_illustration"
                    android:layout_width="104dp"
                    android:layout_height="76dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    
                    <!-- Search bar -->
                    <View
                        android:layout_width="104dp"
                        android:layout_height="24dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/preference_caddy_search_bar" />
                    
                    <!-- App icons -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp">
                        <View
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/preference_caddy_circle" />
                        <View
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/preference_caddy_circle" />
                        <View
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/preference_caddy_circle" />
                        <View
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:background="@drawable/preference_caddy_circle" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/default_list_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/feed_default"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:gravity="center"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Caddy view card -->
        <FrameLayout
            android:id="@+id/caddy_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/preference_caddy_card_background"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center"
                android:minHeight="100dp">

                <!-- Caddy illustration -->
                <LinearLayout
                    android:id="@+id/caddy_illustration"
                    android:layout_width="104dp"
                    android:layout_height="76dp"
                    android:gravity="center"
                    android:orientation="vertical">
                    
                    <!-- Search bar -->
                    <View
                        android:layout_width="104dp"
                        android:layout_height="24dp"
                        android:layout_marginBottom="8dp"
                        android:background="@drawable/preference_caddy_search_bar" />
                    
                    <!-- Folder groups -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingBottom="8dp">
                        <!-- First folder group -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="16dp">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="6dp">
                                <View
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginEnd="6dp"
                                    android:background="@drawable/preference_caddy_circle" />
                                <View
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:background="@drawable/preference_caddy_circle" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <View
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginEnd="6dp"
                                    android:background="@drawable/preference_caddy_circle" />
                                <View
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:background="@drawable/preference_caddy_circle" />
                            </LinearLayout>
                        </LinearLayout>
                        <!-- Second folder group -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:layout_marginBottom="6dp">
                                <View
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginEnd="6dp"
                                    android:background="@drawable/preference_caddy_circle" />
                                <View
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:background="@drawable/preference_caddy_circle" />
                            </LinearLayout>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">
                                <View
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginEnd="6dp"
                                    android:background="@drawable/preference_caddy_circle" />
                                <View
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:background="@drawable/preference_caddy_circle" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/caddy_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/caddy_beta"
                    android:textAppearance="?android:attr/textAppearanceSmall"
                    android:gravity="center"
                    android:layout_marginTop="12dp" />
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

</LinearLayout>
